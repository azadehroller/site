# Sanity Configuration
# Get these values from https://sanity.io/manage
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

# These are aliases - use either set
PUBLIC_SANITY_STUDIO_PROJECT_ID=your-project-id
PUBLIC_SANITY_STUDIO_DATASET=production

# Visual Editing / Presentation Tool
# Controls whether visual editing CAN be enabled (requires BOTH env var AND preview cookie)
#
# How it works:
# - When true: Visual editing loads ONLY for users with 'sanity-preview' cookie (Sanity editors)
# - When false: Visual editing never loads (even for editors)
# - Normal visitors: NEVER see visual editing UI or load React bundle (optimal performance)
# - Sanity editors: Must enable draft mode via /api/draft-mode/enable to get preview cookie
#
# Production: Set to 'true' to allow editors to use visual editing, normal users unaffected
# Development: Set to 'true' to test visual editing features
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=true

# View Transitions (SPA-like client navigation). Set to 'false' to disable and save JS.
# PUBLIC_VIEW_TRANSITIONS_ENABLED=false

# URL of your deployed Sanity Studio (e.g., https://your-site.sanity.studio)
PUBLIC_SANITY_STUDIO_URL=https://your-site.sanity.studio

# API Token for Visual Editing
# Create a token with 'Viewer' permissions at https://sanity.io/manage
# Required when visual editing is enabled
SANITY_API_READ_TOKEN=your-read-token

# Preview Secret for Draft Mode
# Generate a random string for security
# This is used by the presentation tool to enable draft mode
SANITY_PREVIEW_SECRET=your-secret-preview-token

# AI Chatbot Configuration
# The chatbot uses Sanity website content as its knowledge base (1-week cache).
# Ollama handles answer generation. No vector database required.

# Ollama (Local LLM — used for answer generation)
# Install: https://ollama.ai
# Pull model: ollama pull mistral
# Server runs at: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Qdrant Vector Database — no longer used.
# Content is now fetched directly from Sanity and searched with keyword scoring.
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=roller-docs

# Zendesk Help Center
ZENDESK_HOST=mysupport.roller.software

# ─── Deployment target ────────────────────────────────────────────────
# Optional override for which adapter Astro builds with. If unset, the
# adapter is auto-detected (process.env.VERCEL → vercel, process.env.NETLIFY
# → netlify, otherwise vercel). Set this only for non-CI local builds where
# you want to force the other adapter.
# DEPLOY_TARGET=vercel

# ─── Cache purge tokens (Sanity webhook → /api/revalidate) ────────────
# Configure the env vars for whichever platform(s) you want kept fresh.
# Both can be set simultaneously during the Netlify→Vercel comparison phase
# so a single Sanity publish purges both CDNs.

# Netlify (Personal Access Token from Netlify with site:purge scope)
NETLIFY_CACHE_PURGE_TOKEN=
NETLIFY_SITE_ID=

# Vercel (Personal Access Token from vercel.com/account/tokens)
# VERCEL_PROJECT_ID is auto-injected on Vercel deployments; only set
# explicitly if you're invoking the webhook outside Vercel.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=   # only required for team-scoped projects

# Full site URL — used to build absolute purge URLs
SITE=https://www.roller.software
