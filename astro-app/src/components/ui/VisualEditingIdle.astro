---
/**
 * Loads Sanity Visual Editing. Only included when PUBLIC_SANITY_VISUAL_EDITING_ENABLED=true
 * and the user has the sanity-preview cookie. VisualEditing is an Astro component and
 * manages its own client-side script internally — no client:* directive needed or allowed.
 */
import { VisualEditing } from '@sanity/astro/visual-editing';

interface Props {
  zIndex?: number;
}

const { zIndex = 1000 } = Astro.props;
---

<VisualEditing enabled zIndex={zIndex} />
