---
// astro-portabletext passes the block data as `node`
const { node } = Astro.props;
const url = node?.url || '';
const alt = node?.alt || '';
const caption = node?.caption || '';
const inlineStyle = node?.inlineStyle || '';
const width = node?.width || '';
const height = node?.height || '';

// Detect alignment from inline style if not explicitly set
// Check for float in inline style (HubSpot often uses inline styles for float)
let alignment = node?.alignment || 'center';
if (!node?.alignment && inlineStyle) {
  if (inlineStyle.includes('float: right') || inlineStyle.includes('float:right')) {
    alignment = 'right';
  } else if (inlineStyle.includes('float: left') || inlineStyle.includes('float:left')) {
    alignment = 'left';
  }
}

// Check if the image is floated (needs special handling for text wrapping)
const isFloated = alignment === 'left' || alignment === 'right' || 
  inlineStyle.includes('float:') || inlineStyle.includes('float ');

// Determine the CSS class based on alignment
const alignmentClass = alignment === 'left' 
  ? 'image-block--left' 
  : alignment === 'right' 
    ? 'image-block--right' 
    : 'image-block--center';

// Build the style string - prioritize the original inline style from HubSpot
let imgStyle = inlineStyle;
if (!imgStyle) {
  const styleParts: string[] = [];
  if (width) styleParts.push(`width: ${width}`);
  if (height) styleParts.push(`height: ${height}`);
  imgStyle = styleParts.join('; ');
}

// For floated images, apply the style to the container
const containerStyle = isFloated ? imgStyle : undefined;
const imageStyle = isFloated ? undefined : imgStyle;
---

{url && isFloated ? (
  <!-- Floated images: apply style directly to a span wrapper to preserve float behavior -->
  <span class={`image-block-inline ${alignmentClass}`} style={containerStyle}>
    <img 
      src={url} 
      alt={alt} 
      loading="lazy"
      width={width ? width.replace('px', '').replace('%', '') : undefined}
      height={height ? height.replace('px', '').replace('%', '') : undefined}
    />
    {caption && <span class="image-caption">{caption}</span>}
  </span>
) : url && (
  <figure class={`image-block ${alignmentClass}`}>
    <img 
      src={url} 
      alt={alt} 
      loading="lazy" 
      style={imageStyle || undefined}
      width={width ? width.replace('px', '').replace('%', '') : undefined}
      height={height ? height.replace('px', '').replace('%', '') : undefined}
    />
    {caption && <figcaption>{caption}</figcaption>}
  </figure>
)}

<style>
  /* Block-level images (centered, no float) */
  .image-block {
    margin: 1.5rem 0;
  }
  
  .image-block img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }
  
  .image-block figcaption {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: #666;
    text-align: center;
  }

  /* Center aligned (default) */
  .image-block--center {
    text-align: center;
  }
  
  .image-block--center img {
    margin: 0 auto;
    display: block;
  }

  /* Inline floated images - uses original HubSpot styles */
  .image-block-inline {
    display: inline-block;
  }
  
  .image-block-inline img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }
  
  .image-block-inline .image-caption {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: #666;
    text-align: center;
  }

  /* Fallback float styles if inline style not applied */
  .image-block-inline.image-block--left {
    float: left;
    margin: 0 1.5rem 1rem 0;
  }
  
  .image-block-inline.image-block--right {
    float: right;
    margin: 0 0 1rem 1.5rem;
  }

  /* Block-level floated images (legacy) */
  .image-block.image-block--left {
    float: left;
    margin: 0 1.5rem 1rem 0;
    max-width: 50%;
  }
  
  .image-block.image-block--left img {
    max-width: 100%;
  }

  .image-block.image-block--right {
    float: right;
    margin: 0 0 1rem 1.5rem;
    max-width: 50%;
  }
  
  .image-block.image-block--right img {
    max-width: 100%;
  }
</style>

