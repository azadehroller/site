---
/**
 * ChatWidget - AI Documentation Chatbot Component
 * A floating chat widget that connects to the /api/chat endpoint.
 *
 * Features:
 * - Floating toggle button (bottom-right)
 * - Expandable chat panel
 * - Message history within session
 * - Loading states with typing indicator
 * - Source citations as clickable links
 * - Keyboard accessible (Escape to close)
 */

import type { ChatbotConfig } from '@utils/sanity';

interface Props {
  config: ChatbotConfig;
}

const { config } = Astro.props;

const displayName = config.displayName || 'ROLLER Assistant';
const welcomeMessage =
  config.welcomeMessage ||
  'Hi! I can help you find information in the ROLLER documentation. What would you like to know?';
---

<div id="chat-widget" class="chat-widget" data-chatbot>
  <!-- Toggle Button -->
  <button
    id="chat-toggle"
    type="button"
    class="chat-toggle"
    aria-label="Open chat assistant"
    aria-expanded="false"
    aria-controls="chat-panel"
  >
    <!-- Chat icon (when closed) -->
    <svg id="chat-icon-open" class="chat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
      ></path>
    </svg>
    <!-- Close icon (when open) -->
    <svg
      id="chat-icon-close"
      class="chat-icon chat-icon-hidden"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"
      ></path>
    </svg>
  </button>

  <!-- Chat Panel -->
  <div
    id="chat-panel"
    class="chat-panel chat-panel-hidden"
    role="dialog"
    aria-labelledby="chat-title"
  >
    <!-- Resize handles (left edge, top edge, top-left corner) -->
    <div class="chat-resize-handle chat-resize-left" data-resize="left"></div>
    <div class="chat-resize-handle chat-resize-top" data-resize="top"></div>
    <div class="chat-resize-handle chat-resize-corner" data-resize="corner"></div>

    <!-- Header -->
    <div class="chat-header">
      <div class="chat-header-icon">
        <svg class="chat-header-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
          ></path>
        </svg>
      </div>
      <h2 id="chat-title" class="chat-title">{displayName}</h2>
    </div>

    <!-- Messages Container -->
    <div id="chat-messages" class="chat-messages" aria-live="polite" aria-atomic="false">
      <!-- Welcome message -->
      <div class="chat-message chat-message-bot">
        <div class="chat-bubble chat-bubble-bot">
          <p class="chat-text">{welcomeMessage}</p>
        </div>
      </div>
    </div>

    <!-- Input Area -->
    <form id="chat-form" class="chat-form">
      <div class="chat-input-wrapper">
        <textarea
          id="chat-input"
          placeholder="Ask a question..."
          class="chat-input"
          autocomplete="off"
          aria-label="Type your question"
          rows="1"
        ></textarea>
        <!-- Mic button — hidden by default; revealed by JS only when SpeechRecognition is supported -->
        <button
          id="chat-mic"
          type="button"
          class="chat-mic chat-mic-hidden"
          aria-label="Use microphone"
        >
          <svg class="chat-mic-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"
            ></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 10v2a7 7 0 0 1-14 0v-2"
            ></path>
            <line stroke-linecap="round" stroke-width="2" x1="12" y1="19" x2="12" y2="23"></line>
            <line stroke-linecap="round" stroke-width="2" x1="8" y1="23" x2="16" y2="23"></line>
          </svg>
        </button>
        <button
          id="chat-submit"
          type="submit"
          class="chat-submit"
          aria-label="Send message"
        >
          <svg class="chat-submit-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
          </svg>
        </button>
      </div>
      <p id="chat-error" class="chat-error chat-error-hidden"></p>
    </form>
    <!-- Persistent CTA buttons -->
    <div class="chat-cta-wrapper">
      <a class="chat-cta-btn chat-cta-get-started" href="/get-started">Get Started</a>
      <a class="chat-cta-btn chat-cta-book-demo" href="/">Book a Demo</a>
    </div>
  </div>
</div>

<style>
  .chat-widget {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9999;
  }

  .chat-toggle {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background-color: var(--primary-50);
    color: var(--neutral-white);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-xlarge);
    transition: background-color 0.2s, transform 0.2s;
  }

  .chat-toggle:hover {
    background-color: var(--primary-60);
    transform: scale(1.05);
  }

  .chat-toggle:focus {
    outline: 2px solid var(--primary-30);
    outline-offset: 2px;
  }

  .chat-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .chat-icon-hidden {
    display: none;
  }

  .chat-panel {
    position: absolute;
    bottom: 5rem;
    right: 0;
    width: 28rem;
    max-width: calc(100vw - 3rem);
    height: 500px;
    max-height: calc(100vh - 200px);
    background-color: var(--neutral-white);
    border-radius: 1rem;
    box-shadow: var(--shadow-xxlarge);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .chat-panel-hidden {
    display: none;
  }

  .chat-header {
    background-color: var(--primary-50);
    color: var(--neutral-white);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .chat-header-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background-color: var(--primary-40);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chat-header-svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .chat-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0;
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .chat-message {
    display: flex;
  }

  .chat-message-bot {
    justify-content: flex-start;
  }

  .chat-message-user {
    justify-content: flex-end;
  }

  .chat-bubble {
    max-width: 85%;
    padding: 0.75rem 1rem;
    border-radius: 1rem;
  }

  .chat-bubble-bot {
    background-color: var(--neutral-10);
    border-top-left-radius: 0;
  }

  .chat-bubble-user {
    background-color: var(--primary-50);
    color: var(--neutral-white);
    border-bottom-right-radius: 0;
  }

  .chat-text {
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
    color: #033180;
    font-weight: 700;
  }

  .chat-bubble-user .chat-text {
    color: #033180;
    font-size: 0.9375rem;
    font-weight: 700;
  }

  :global(.chat-paragraph) {
    margin: 0 0 0.75rem 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #033180;
  }

  :global(.chat-paragraph:last-child) {
    margin-bottom: 0;
  }

  :global(.chat-paragraph-user) {
    color: #033180;
    font-size: 1rem;
    font-weight: 700;
    padding: .5rem;
    background: var(--primary-10);
    border-radius: 10px 10px 0 10px;
    display: inline-flex;
  }

  :global(.chat-section-header) {
    margin: 1rem 0 0.5rem 0;
    font-size: 0.9375rem;
    line-height: 1.4;
    color: #033180;
    font-weight: 700;
  }

  :global(.chat-section-header:first-child) {
    margin-top: 0;
  }

  :global(.chat-section-header-user) {
    color: #033180;
    font-size: 1rem;
    font-weight: 700;
  }

  :global(.chat-ordered-list),
  :global(.chat-unordered-list) {
    margin: 0.5rem 0;
    padding-left: 1.5rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #033180;
  }

  :global(.chat-ordered-list) {
    list-style-type: decimal;
    list-style-position: outside;
  }

  :global(.chat-unordered-list) {
    list-style-type: disc;
    list-style-position: outside;
  }

  :global(.chat-ordered-list li),
  :global(.chat-unordered-list li) {
    margin-bottom: 0.35rem;
    padding-left: 0.25rem;
    display: list-item;
  }

  :global(.chat-ordered-list li:last-child),
  :global(.chat-unordered-list li:last-child) {
    margin-bottom: 0;
  }

  .chat-bubble-user :global(.chat-ordered-list),
  .chat-bubble-user :global(.chat-unordered-list) {
    color: #033180;
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .chat-sources {
    margin-top: 0.75rem;
  }

  :global(.chat-sources-separator) {
    border: none;
    border-top: .5px solid #084dc5;
    margin: 1rem 0;
  }

  :global(.chat-sources-title) {
    font-size: 0.875rem;
    color: var(--neutral-60);
    font-weight: 700;
    margin: 0 0 0.5rem 0;
  }

  :global(.chat-source-link) {
    display: inline-block;
    color: #074dc5 !important;
    text-decoration: none;
    font-size: 0.75rem;
    line-height: 1.6;
    font-weight: 500;
  }

  :global(.chat-source-link:hover) {
    text-decoration: underline;
    color: #0541a0 !important;
  }

  /* Inline links rendered from Markdown [text](url) in bot responses */
  :global(.chat-inline-link) {
    color: #074dc5 !important;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 500;
  }

  :global(.chat-inline-link:hover) {
    color: #0541a0 !important;
    text-decoration-thickness: 2px;
  }

  .chat-cta-wrapper {
    display: flex;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem 0.75rem;
    flex-wrap: wrap;
  }

  .chat-cta-btn {
    display: inline-block;
    padding: 0.5rem 1.125rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #ffffff !important;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s;
    line-height: 1;
  }

  .chat-cta-btn:hover {
    opacity: 0.85;
    color: #ffffff !important;
    text-decoration: none;
  }

  .chat-cta-get-started {
    background-color: var(--secondary-50, #ff290c);
  }

  .chat-cta-book-demo {
    background-color: var(--primary-50, #033180);
  }

  .chat-form {
    border-top: 1px solid var(--neutral-20);
    padding: 0.75rem;
  }

  .chat-input-wrapper {
    display: flex;
    gap: 0.5rem;
    align-items: flex-end; /* keeps mic + send buttons pinned to the bottom as textarea grows */
  }

  .chat-input {
    flex: 1;
    padding: 0.5rem 1rem;
    border: 1px solid var(--neutral-30);
    border-radius: 1rem;
    font-size: 0.875rem;
    font-family: inherit;
    line-height: 1.5;
    outline: none;
    resize: none;         /* hide the drag handle */
    overflow-y: hidden;   /* no scrollbar until max-height is reached */
    max-height: 9rem;     /* ~5 lines before scrolling kicks in */
    transition: border-color 0.2s;
  }

  .chat-input:focus {
    border-color: var(--primary-50);
    box-shadow: 0 0 0 2px var(--primary-10);
  }

  .chat-submit {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--secondary-50);
    color: var(--neutral-white);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s;
  }

  .chat-submit:hover {
    background-color: var(--secondary-70);
  }

  .chat-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .chat-submit-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .chat-mic-hidden {
    display: none;
  }

  .chat-mic {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--neutral-10);
    color: var(--primary-50);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s;
    flex-shrink: 0;
  }

  .chat-mic:hover {
    background-color: var(--neutral-20);
  }

  .chat-mic-icon {
    width: 1.125rem;
    height: 1.125rem;
  }

  /* Pulsing red ring while listening — shown on Chrome/Edge only */
  .chat-mic-listening {
    background-color: #fee2e2;
    color: #dc2626;
    animation: mic-pulse 1.2s infinite ease-in-out;
  }

  @keyframes mic-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.35); }
    50%       { box-shadow: 0 0 0 6px rgba(220, 38, 38, 0); }
  }

  .chat-error {
    color: var(--error-50);
    font-size: 0.75rem;
    margin: 0.5rem 0.5rem 0;
  }

  .chat-error-hidden {
    display: none;
  }

  :global(.thinking-text) {
    font-size: 0.875rem;
    color: var(--primary-50);
    font-weight: 500;
    margin: 0 0 0.5rem 0;
    animation: blink 1s infinite ease-in-out;
    will-change: opacity; /* composited layer — avoids layout reflow on each frame */
  }

  @keyframes blink {
    0%, 100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }

  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 0.5rem 0;
  }

  .typing-indicator span {
    width: 8px;
    height: 8px;
    background-color: var(--neutral-40);
    border-radius: 50%;
    animation: typing 1.4s infinite ease-in-out;
  }

  .typing-indicator span:nth-child(1) {
    animation-delay: 0s;
  }
  .typing-indicator span:nth-child(2) {
    animation-delay: 0.2s;
  }
  .typing-indicator span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes typing {
    0%,
    60%,
    100% {
      transform: translateY(0);
    }
    30% {
      transform: translateY(-4px);
    }
  }

  /* ── Resize handles ─────────────────────────────────────────────────── */
  .chat-resize-handle {
    position: absolute;
    z-index: 20;
    transition: background 0.15s;
  }

  /* Left edge — drag horizontally to widen/narrow */
  .chat-resize-left {
    top: 1rem;        /* clear the corner zone */
    bottom: 0;
    left: 0;
    width: 6px;
    cursor: ew-resize;
    border-radius: 1rem 0 0 1rem;
  }

  /* Top edge — drag vertically to raise/lower */
  .chat-resize-top {
    top: 0;
    left: 1rem;       /* clear the corner zone */
    right: 0;
    height: 6px;
    cursor: ns-resize;
    border-radius: 0 1rem 0 0;
  }

  /* Top-left corner — drag diagonally */
  .chat-resize-corner {
    top: 0;
    left: 0;
    width: 16px;
    height: 16px;
    cursor: nwse-resize;
    border-radius: 1rem 0 0 0;
  }

  .chat-resize-handle:hover {
    background: rgba(3, 49, 128, 0.12);
  }
  /* ── End resize handles ─────────────────────────────────────────────── */

  /* Mobile responsive */
  @media (max-width: 640px) {
    .chat-panel {
      width: calc(100vw - 2rem);
      right: -0.5rem;
    }
  }
</style>

<script>
  import { initChatWidget } from './chat-widget';
  // Re-runs on every page load, including after View Transitions DOM swaps.
  document.addEventListener('astro:page-load', initChatWidget);
</script>
