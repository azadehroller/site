---
/**
 * Get Started Page Route
 * Fetches the Get Started singleton from Sanity and renders it
 */
import GetStartedTemplate from "@templates/page/GetStarted.astro";
import { getGetStartedPage, getLayoutData } from "@utils/sanity";

const [{ data: page }, layoutSanity] = await Promise.all([
  getGetStartedPage(Astro.request),
  getLayoutData(Astro.request),
]);
---

<GetStartedTemplate page={page} layoutSanity={layoutSanity} />

