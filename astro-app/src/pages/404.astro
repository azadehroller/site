---
import Layout from "@layouts/Layout.astro";
import { getLayoutData } from "@utils/sanity";

// Astro automatically serves this file for any unmatched route AND for any
// `Astro.redirect('/404')` call. Without this file, redirects to /404 fall
// through to the catch-all `[slug].astro`, which itself redirects to /404 →
// infinite loop → Vercel 508 INFINITE_LOOP.
//
// SSR enabled so we can pull header/footer from Sanity like every other page.
export const prerender = false;

const layoutSanity = await getLayoutData(Astro.request);

// Tell crawlers (and the browser) this is a 404, not a soft-redirect or 200.
Astro.response.status = 404;
Astro.response.statusText = 'Not Found';
---

<Layout title="Page not found" layoutSanity={layoutSanity}>
  <section class="not-found">
    <div class="not-found__inner">
      <p class="not-found__eyebrow">404</p>
      <h1 class="not-found__title">We couldn’t find that page</h1>
      <p class="not-found__body">
        The link you followed may be broken, or the page may have been moved.
      </p>
      <a class="not-found__cta" href="/">Back to home</a>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
  }
  .not-found__inner {
    max-width: 32rem;
    text-align: center;
  }
  .not-found__eyebrow {
    font-size: 0.875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
    opacity: 0.6;
  }
  .not-found__title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0 0 1rem;
  }
  .not-found__body {
    margin: 0 0 2rem;
    opacity: 0.8;
  }
  .not-found__cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    background: currentColor;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
  }
  .not-found__cta:hover {
    opacity: 0.85;
  }
</style>
