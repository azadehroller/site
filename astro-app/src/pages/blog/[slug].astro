---
import BlogPost from "@templates/blog/BlogPost.astro";
import { getPost, getRelatedPosts, getLayoutData } from "@utils/sanity";
import type { Post } from "@utils/sanity";

// SSR enabled for preview/draft mode
export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/");
}

const [{ data: post }, layoutSanity] = await Promise.all([
  getPost(slug, Astro.request),
  getLayoutData(Astro.request),
]);

if (!post) {
  return Astro.redirect("/");
}

const topicIds = post.topics?.filter((t: any) => t?._id).map((t: any) => t._id as string) || [];

let relatedPosts: Post[] = [];
if (topicIds.length > 0) {
  const { data: related } = await getRelatedPosts(topicIds, post._id, 3, Astro.request);
  relatedPosts = (related as Post[]) || [];
}
---

<BlogPost post={post} relatedPosts={relatedPosts} layoutSanity={layoutSanity} />
