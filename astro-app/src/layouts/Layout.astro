// https://docs.astro.build/en/guides/view-transitions/
import { ViewTransitions } from 'astro:transitions';
import '@styles/global.css';
import Footer from '@components/globals/Footer.astro';
import Header from '@components/globals/Header.astro';
import AnnouncementBar from '@components/globals/AnnouncementBar.astro';
import ChatWidget from '@components/chat/ChatWidget.astro';
import { getLayoutData, type AnnouncementBarSettings } from '@utils/sanity';

// Visual Editing: Only load for authenticated Sanity editors (via preview cookie)
// This keeps React/Sanity out of main bundle for normal users (performance optimization)
// Check runtime cookie instead of build-time env var for per-user control
const cookieHeader = Astro.request.headers.get('cookie') || '';
const isPreview = /\bsanity-preview=true\b/.test(cookieHeader);
const visualEditingEnabled = import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === 'true' && isPreview;
const VisualEditingIdle = visualEditingEnabled ? (await import('@components/ui/VisualEditingIdle.astro')).default : null;

interface SEOImage {
  asset?: {
    _ref?: string;
    url?: string;
  };
  alt?: string;
}

interface SEOProps {
  seoTitle?: string;
  seoDescription?: string;
  seoImage?: SEOImage;
  noIndex?: boolean;
  canonicalUrl?: string;
  // For blog posts - fallback image from featured image
  fallbackImage?: {
    url?: string;
    alt?: string;
  };
  // Fallback description (e.g., excerpt for blog posts)
  fallbackDescription?: string;
}

interface Props {
  title: string;
  headDocument?: string;
  headerTheme?: 'default' | 'dark' | 'light' | 'industry_report';
  announcementBar?: AnnouncementBarSettings;
  seo?: SEOProps;
  /** URL of the LCP image to preload for faster rendering */
  lcpImage?: string;
}

const { title, headDocument, headerTheme = 'light', announcementBar, seo, lcpImage } = Astro.props;

// SEO values with fallbacks
const pageTitle = seo?.seoTitle || title;
const metaDescription = seo?.seoDescription || seo?.fallbackDescription;
// Use seoImage if set, otherwise fall back to fallbackImage (e.g., featured image for blog posts)
const ogImage = seo?.seoImage?.asset?.url || seo?.fallbackImage?.url;
const ogImageAlt = seo?.seoImage?.alt || seo?.fallbackImage?.alt || pageTitle;
const noIndex = seo?.noIndex;
const canonicalUrl = seo?.canonicalUrl || Astro.url.href;

// Show announcement bar if enabled and has text
const showAnnouncementBar = announcementBar?.enabled && announcementBar?.text;

// View Transitions add client-side navigation JS. Set PUBLIC_VIEW_TRANSITIONS_ENABLED=false to disable for better perf.
const viewTransitionsEnabled = import.meta.env.PUBLIC_VIEW_TRANSITIONS_ENABLED !== 'false';
// Localhost/dev: disable external trackers (gtag/GTM, Facebook, etc.) that may be blocked by course policy.
// Set PUBLIC_ENABLE_THIRD_PARTY_SCRIPTS=true in .env to enable locally for testing
const enableThirdPartyScripts = import.meta.env.PROD || import.meta.env.PUBLIC_ENABLE_THIRD_PARTY_SCRIPTS === 'true';

// Fetch header, footer, and chatbot config from Sanity in a single merged query
// This reduces 3 API calls to 1, improving performance by ~150-250ms
const { data: layoutData, perspective } = await getLayoutData(Astro.request);
const headerData = layoutData?.header;
const footerData = layoutData?.footer;
const chatbotConfig = layoutData?.chatbot;

// Log preview mode for debugging (only in dev)
if (import.meta.env.DEV) {
  console.log('[Layout] Visual editing:', {
    isPreview,
    visualEditingEnabled,
    perspective,
    hasStega: perspective === 'drafts',
    componentLoaded: !!VisualEditingIdle
  });
}

