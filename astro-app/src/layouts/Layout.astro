---
// https://docs.astro.build/en/guides/view-transitions/
import { ViewTransitions } from 'astro:transitions';
import '@styles/global.css';
import Footer from '@components/globals/Footer.astro';
import Header from '@components/globals/Header.astro';
import AnnouncementBar from '@components/globals/AnnouncementBar.astro';
import ChatWidget from '@components/chat/ChatWidget.astro';
import { getLayoutData, type AnnouncementBarSettings, type LayoutSanityResult } from '@utils/sanity';

// Visual Editing: Only load for authenticated Sanity editors (via preview cookie)
// This keeps React/Sanity out of main bundle for normal users (performance optimization)
// Check runtime cookie instead of build-time env var for per-user control
const cookieHeader = Astro.request.headers.get('cookie') || '';
const isPreview = /\bsanity-preview=true\b/.test(cookieHeader);
const visualEditingEnabled = import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === 'true' && isPreview;
const VisualEditingIdle = visualEditingEnabled ? (await import('@components/ui/VisualEditingIdle.astro')).default : null;

interface SEOImage {
  asset?: {
    _ref?: string;
    url?: string;
  };
  alt?: string;
}

interface SEOProps {
  seoTitle?: string;
  seoDescription?: string;
  seoImage?: SEOImage;
  noIndex?: boolean;
  canonicalUrl?: string;
  // For blog posts - fallback image from featured image
  fallbackImage?: {
    url?: string;
    alt?: string;
  };
  // Fallback description (e.g., excerpt for blog posts)
  fallbackDescription?: string;
}

interface Props {
  title: string;
  headDocument?: string;
  headerTheme?: 'default' | 'dark' | 'light' | 'industry_report';
  announcementBar?: AnnouncementBarSettings;
  seo?: SEOProps;
  /** URL of the LCP image to preload for faster rendering */
  lcpImage?: string;
  /**
   * When provided, Layout skips `getLayoutData` (fetch alongside page data via `Promise.all` for lower TTFB).
   */
  layoutSanity?: LayoutSanityResult;
}

const { title, headDocument, headerTheme = 'light', announcementBar, seo, lcpImage, layoutSanity } = Astro.props;

// SEO values with fallbacks
const pageTitle = seo?.seoTitle || title;
const metaDescription = seo?.seoDescription || seo?.fallbackDescription;
// Use seoImage if set, otherwise fall back to fallbackImage (e.g., featured image for blog posts)
const ogImage = seo?.seoImage?.asset?.url || seo?.fallbackImage?.url;
const ogImageAlt = seo?.seoImage?.alt || seo?.fallbackImage?.alt || pageTitle;
const noIndex = seo?.noIndex;
const canonicalUrl = seo?.canonicalUrl || Astro.url.href;

// Show announcement bar if enabled and has text
const showAnnouncementBar = announcementBar?.enabled && announcementBar?.text;

// View Transitions add client-side navigation JS. Set PUBLIC_VIEW_TRANSITIONS_ENABLED=false to disable for better perf.
const viewTransitionsEnabled = import.meta.env.PUBLIC_VIEW_TRANSITIONS_ENABLED !== 'false';
// Localhost/dev: disable external trackers (gtag/GTM, Facebook, etc.) that may be blocked by course policy.
// Set PUBLIC_ENABLE_THIRD_PARTY_SCRIPTS=true in .env to enable locally for testing
const enableThirdPartyScripts = import.meta.env.PROD || import.meta.env.PUBLIC_ENABLE_THIRD_PARTY_SCRIPTS === 'true';

// Usercentrics draft testing (dev): see comments next to the CMP script in <head>
const usercentricsClearStorage =
  import.meta.env.DEV && import.meta.env.PUBLIC_USERCENTRICS_CLEAR_STORAGE === 'true'
const usercentricsDebug =
  import.meta.env.DEV && import.meta.env.PUBLIC_USERCENTRICS_DEBUG === 'true'

// Fetch header/footer/chatbot unless the page already loaded it in parallel (see layoutSanity prop)
const { data: layoutData, perspective } = layoutSanity ?? (await getLayoutData(Astro.request));
const headerData = layoutData?.header;
const footerData = layoutData?.footer;
const chatbotConfig = layoutData?.chatbot;

// Log preview mode for debugging (only in dev)
if (import.meta.env.DEV) {
  console.log('[Layout] Visual editing:', {
    isPreview,
    visualEditingEnabled,
    perspective,
    hasStega: perspective === 'drafts',
    componentLoaded: !!VisualEditingIdle
  });
}

/** Site-wide Organization schema (JSON-LD). Built in frontmatter and stringified for safe output. */
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  legalName: 'ROLLER Networks Pty Ltd',
  name: 'ROLLER',
  description:
    'Software for attractions, leisure, and entertainment venues — ticketing, POS, memberships, and more.',
  logo: 'https://3375779.fs1.hubspotusercontent-na1.net/hubfs/3375779/ROLLER%20Logo.svg',
  url: 'https://www.roller.software/',
  foundingDate: '2010',
  sameAs: [
    'https://www.facebook.com/ROLLERSOFTWARE/',
    'https://www.youtube.com/channel/UC7k0OBldm_7etXYmUrJopvA',
    'https://www.instagram.com/rollersoftware/',
    'https://www.linkedin.com/company/roller/',
  ],
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      areaServed: 'Worldwide',
      url: 'https://www.roller.software/support',
    },
    {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      areaServed: 'US',
      telephone: '+1 855 939 3313',
      url: 'https://www.roller.software/support',
    },
    {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      areaServed: 'UK',
      telephone: '+44 808 258 0167',
      url: 'https://www.roller.software/support',
    },
    {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      areaServed: 'AU',
      telephone: '+61 3 8592 6384',
      url: 'https://www.roller.software/support',
    },
  ],
} as const;

---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="generator" content={Astro.generator} />

    <!--
      Usercentrics CMP (draft): load early in <head> per https://usercentrics.com/docs/web/implementation/ui/
      If the SDK loads but no banner: (1) existing consent in storage — use PUBLIC_USERCENTRICS_CLEAR_STORAGE=true
      (2) Admin geolocation/rules — isConsentRequired is false outside target regions (3) draft not saved in Admin
      (4) domain not allowlisted for localhost — add in Usercentrics Admin → Implementation
    -->
    {usercentricsClearStorage && (
      <script is:inline>
        (function () {
          try {
            function clearKeys(store) {
              for (var i = store.length - 1; i >= 0; i--) {
                var k = store.key(i)
                if (k && (/^uc/i.test(k) || /usercentrics/i.test(k))) store.removeItem(k)
              }
            }
            clearKeys(localStorage)
            clearKeys(sessionStorage)
          } catch (e) {}
        })()
      </script>
    )}
    <script
      is:inline
      async
      id="usercentrics-cmp"
      src="https://web.cmp.usercentrics.eu/ui/loader.js"
      data-settings-id="2IPQ2tsbqQMCiu"
      data-draft="true"
    ></script>
    {usercentricsDebug && (
      <script is:inline>
        window.addEventListener('UC_UI_INITIALIZED', function () {
          var cmp = window.__ucCmp
          if (!cmp) {
            console.warn('[Usercentrics] UC_UI_INITIALIZED fired but window.__ucCmp is missing')
            return
          }
          cmp
            .isConsentRequired()
            .then(function (required) {
              console.info(
                '[Usercentrics] isConsentRequired =',
                required,
                '— if false, your Admin rules/geolocation usually mean no banner in this region/browser; draft must also be saved in Admin.'
              )
            })
            .catch(function (err) {
              console.warn('[Usercentrics] isConsentRequired failed', err)
            })
        })
      </script>
    )}

    <!-- Preconnect to critical origins for faster resource loading -->
    <!-- Sanity CDN serves all CMS images — preconnect saves ~100-200ms on first image load -->
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.sanity.io" />
    <!-- Usercentrics CMP script domain -->
    <link rel="preconnect" href="https://web.cmp.usercentrics.eu" crossorigin />
    <link rel="dns-prefetch" href="https://web.cmp.usercentrics.eu" />
    {enableThirdPartyScripts && (
      <>
        <!-- Preconnects for deferred trackers so the post-load fetch is faster (no full TLS round-trip when the script finally runs). -->
        <link rel="preconnect" href="https://js.hs-scripts.com" crossorigin />
        <link rel="preconnect" href="https://track.hubspot.com" crossorigin />
        <link rel="preconnect" href="https://www.clarity.ms" crossorigin />
        <link rel="preconnect" href="https://app.posthog.com" crossorigin />
        <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
      </>
    )}

    <!-- Preload LCP image for faster rendering (reduces resource load delay) -->
    {lcpImage && (
      <link rel="preload" as="image" href={lcpImage} fetchpriority="high" />
    )}

    <!-- SEO Meta Tags -->
    <!-- Staging site: always block indexing. The X-Robots-Tag header in netlify.toml
         provides a second layer, and robots.txt disallows all crawling. -->
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    
    <title>{pageTitle}</title>
    {metaDescription && <meta name="description" content={metaDescription} />}
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    {metaDescription && <meta property="og:description" content={metaDescription} />}
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:alt" content={ogImageAlt} />}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    {metaDescription && <meta name="twitter:description" content={metaDescription} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="https://www.roller.software/hubfs/ROLLER%20Chevron%20(1).png">

    {enableThirdPartyScripts && (
      <>
        <!--
          Defer heavy consent-gated trackers (Facebook Pixel, Clarity, PostHog) until after window.load.
          Consent gating is unchanged — Usercentrics still controls whether they execute at all.
          The MutationObserver auto-disconnects once all targets are seen (or after 60s) to avoid
          a long-lived subtree observer on document.documentElement.
        -->
        <script is:inline>
          (function () {
            var DEFERRED = ['fbevents.js', 'clarity.ms', 'app.posthog.com'];
            var seen = Object.create(null);

            function matchTarget(src) {
              for (var i = 0; i < DEFERRED.length; i++) {
                if (src.indexOf(DEFERRED[i]) !== -1) return DEFERRED[i];
              }
              return null;
            }

            function deferScript(script) {
              if (!script || script.nodeName !== 'SCRIPT') return false;
              if (script.getAttribute('data-deferred-injected') === '1') return false;
              var src = script.src || '';
              var key = matchTarget(src);
              if (!key) return false;
              var async = script.async;
              if (script.parentNode) script.parentNode.removeChild(script);
              function inject() {
                var s = document.createElement('script');
                s.async = async;
                s.src = src;
                s.setAttribute('data-deferred-injected', '1');
                document.head.appendChild(s);
              }
              if (document.readyState === 'complete') setTimeout(inject, 0);
              else window.addEventListener('load', inject, { once: true });
              seen[key] = true;
              return true;
            }

            function allSeen() {
              for (var i = 0; i < DEFERRED.length; i++) {
                if (!seen[DEFERRED[i]]) return false;
              }
              return true;
            }

            try {
              document.querySelectorAll('script[src]').forEach(deferScript);
              if (allSeen()) return;

              var obs = new MutationObserver(function (records) {
                for (var i = 0; i < records.length; i++) {
                  var added = records[i].addedNodes;
                  for (var j = 0; j < added.length; j++) {
                    deferScript(added[j]);
                  }
                }
                if (allSeen()) obs.disconnect();
              });
              obs.observe(document.documentElement, { childList: true, subtree: true });
              setTimeout(function () { try { obs.disconnect(); } catch (e) {} }, 60000);
            } catch (e) {}
          })();
        </script>
        <!-- Consent-gated marketing tags: type="text/plain" prevents execution until Usercentrics grants consent -->
        <script type="text/plain"
          data-src="https://app.posthog.com/static/array.js"
          data-attrs='{"async":true}'>
        </script>

        <script type="text/plain"
          data-src="https://ct.capterra.com/capterra_tracker.js?vid=2115025&vkey=df330b132e6af93651d818491be94c26"
          data-attrs='{"async":true}'>
        </script>

        <script type="text/plain"
          data-src="https://www.clarity.ms/tag/tqv8fkrhwq?ref=gtm"
          data-attrs='{"async":true}'>
        </script>

        <script type="text/plain"
          data-src="https://bat.bing.com/bat.js"
          data-attrs='{"async":true}'>
        </script>

        <script type="text/plain"
          data-src="https://amplify.outbrain.com/cp/obtp.js"
          data-attrs='{"async":true}'>
        </script>

        <script type="text/plain"
          data-src="https://connect.facebook.net/en_US/fbevents.js"
          data-attrs='{"async":true}'>
        </script>

        <script type="text/plain"
          data-src="https://www.redditstatic.com/ads/pixel.js"
          data-attrs='{"async":true}'>
        </script>

        <script type="text/plain"
          data-src="https://secure.quantserve.com/quant.js"
          data-attrs='{"async":true}'>
        </script>

        <script type="text/plain"
          data-src="https://snap.licdn.com/li.lms-analytics/insight.min.js"
          data-attrs='{"async":true}'>
        </script>

      </>
    )}

    {enableThirdPartyScripts && (
      <>
        <!-- Legacy consent scripts — disabled, Usercentrics handles consent now -->
        <!--
        <script is:inline defer src="/scripts/regional-consent.js"></script>
        <script is:inline defer src="/scripts/consent-controller.js"></script>
        -->

        <!-- HubSpot tracking: inject after window.load so it does not compete with LCP (forms still use js.hsforms.net/embed/v2.js separately). -->
        <script is:inline>
          (function () {
            if (window.__hsScriptsLoaderScheduled) return
            window.__hsScriptsLoaderScheduled = true
            function injectHubSpotTracker() {
              if (document.getElementById('hs-script-loader')) return
              var s = document.createElement('script')
              s.id = 'hs-script-loader'
              s.async = true
              s.defer = true
              s.src = 'https://js.hs-scripts.com/3375779.js'
              document.head.appendChild(s)
            }
            if (document.readyState === 'complete') injectHubSpotTracker()
            else window.addEventListener('load', injectHubSpotTracker, { once: true })
          })()
        </script>

        <link rel="preconnect" href="https://dev.visualwebsiteoptimizer.com">
        <script
          type="text/plain"
          data-src="https://dev.visualwebsiteoptimizer.com/j.php?a=1171237"
          data-attrs='{"async":true,"id":"vwoCode"}'>
        </script>
        <script is:inline
          type="text/plain"
          data-src="https://tracking.g2crowd.com/attribution_tracking/conversions/2535.js?p=https://www.roller.software/featur&amp;e="
          data-attrs='{"async":true}'>
        </script>

        <meta name="google-site-verification" content="8gRa8N41J52kOXwPTGI_PXAQk-OkWhwvxDfxFOCSsiM">
        <meta http-equiv="content-language" content="en">

      </>
    )}

    <!-- Custom head content from CMS -->
    {headDocument && <Fragment set:html={headDocument} />}

    <!-- Named slot for additional head content -->
    <slot name="head" />
  </head>
  <body class="m-0 bg-white font-sans">
    {showAnnouncementBar && (
      <AnnouncementBar
        display={true}
        text={announcementBar?.text}
        ctaText={announcementBar?.ctaText}
        link={announcementBar?.link}
        countdownDate={announcementBar?.countdownDate}
        theme={announcementBar?.theme}
      />
    )}
    <div class="main-wrapper">
      <Header
        logo={headerData?.logo}
        logoDark={headerData?.logoDark}
        logoAlt={headerData?.logoAlt}
        logoLink={headerData?.logoLink}
        navItems={headerData?.navItems}
        megaMenus={headerData?.megaMenus}
        buttons={headerData?.buttons}
        headerTheme={headerTheme}
      />
      <main id="main-content" class="sm:mt-0">
        <slot />
      </main>
    </div>
    <Footer
      newsletterTitle={footerData?.newsletterTitle}
      newsletterDescription={footerData?.newsletterDescription}
      newsletterButtonText={footerData?.newsletterButtonText}
      newsletterPlaceholder={footerData?.newsletterPlaceholder}
      quickLinks={footerData?.quickLinks}
      columns={footerData?.columns}
      copyrightText={footerData?.copyrightText}
      legalLinks={footerData?.legalLinks}
      socialLinks={footerData?.socialLinks}
      socialText={footerData?.socialText}
      showFloatingButton={false}
      floatingButtonUrl={footerData?.floatingButtonUrl}
      floatingButtonPrimaryText={footerData?.floatingButtonPrimaryText}
      floatingButtonSecondaryText={footerData?.floatingButtonSecondaryText}
    />
    {chatbotConfig?.enabled && <ChatWidget config={chatbotConfig} />}
    {/* View Transitions at end of body so script doesn't block head / above-the-fold parse */}
    {viewTransitionsEnabled && <ViewTransitions />}
    {/* Visual Editing: only when enabled; hydrates on idle so it never blocks LCP */}
    {VisualEditingIdle && <VisualEditingIdle zIndex={1000} />}
  </body>
</html>

